<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg"
    android:padding="32dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="NATAPPS" android:textColor="@color/accent" android:textSize="40sp"
        android:fontFamily="sans-serif-condensed" android:letterSpacing="0.15"
        android:gravity="center" android:layout_marginBottom="4dp" />
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="sensor recorder" android:textColor="@color/muted" android:textSize="13sp"
        android:gravity="center" android:layout_marginBottom="52dp" />

    <Button android:id="@+id/btnGoogleSignIn"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Continue with Google" android:textSize="15sp" android:letterSpacing="0.04"
        android:textColor="@color/bg" android:background="@color/accent"
        android:layout_marginBottom="24dp" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border" android:layout_marginBottom="20dp" />

    <EditText android:id="@+id/etEmail"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="Email" android:inputType="textEmailAddress"
        android:textSize="15sp" android:textColor="@color/accent2" android:textColorHint="@color/muted"
        android:background="@color/surface" android:paddingStart="14dp" android:paddingEnd="14dp"
        android:layout_marginBottom="10dp" />

    <EditText android:id="@+id/etPassword"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="Password" android:inputType="textPassword"
        android:textSize="15sp" android:textColor="@color/accent2" android:textColorHint="@color/muted"
        android:background="@color/surface" android:paddingStart="14dp" android:paddingEnd="14dp"
        android:layout_marginBottom="14dp" />

    <Button android:id="@+id/btnEmailSignIn"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="Sign in / Create account" android:textSize="14sp"
        android:textColor="@color/accent" android:background="@color/surface"
        android:layout_marginBottom="20dp" />

    <Button android:id="@+id/btnGuest"
        android:layout_width="match_parent" android:layout_height="48dp"
        android:text="Try as Guest" android:textSize="13sp"
        android:textColor="@color/muted" android:background="@color/bg"
        android:layout_marginTop="4dp" />

</LinearLayout>
