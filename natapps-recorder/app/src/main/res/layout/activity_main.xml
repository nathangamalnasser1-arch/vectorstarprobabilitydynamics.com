<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header + user -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="2dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NATAPPS RECORDER"
                android:textColor="@color/accent" android:textSize="26sp"
                android:fontFamily="sans-serif-condensed" android:letterSpacing="0.12" />
            <Button android:id="@+id/btnSignOut"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="SIGN OUT" android:textSize="9sp"
                android:textColor="@color/muted" android:background="@color/surface"
                android:paddingStart="10dp" android:paddingEnd="10dp" />
        </LinearLayout>
        <TextView android:id="@+id/tvUserInfo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="@color/muted" android:textSize="11sp"
            android:layout_marginBottom="12dp" />

        <!-- ROLE -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border" android:layout_marginBottom="10dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="ROLE" android:textColor="@color/muted"
            android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <Button android:id="@+id/btnRoleSensor1"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="SENSOR 1" android:textSize="11sp"
                android:textColor="@color/bg" android:background="@color/accent"
                android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btnRoleHub"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="HUB" android:textSize="11sp"
                android:textColor="@color/accent" android:background="@color/surface"
                android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btnRoleCam"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="CAM" android:textSize="11sp"
                android:textColor="@color/accent" android:background="@color/surface" />
        </LinearLayout>
        <TextView android:id="@+id/tvRoleHint"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Phone 1 — IMU sensor, streams to HUB via Bluetooth"
            android:textColor="@color/muted" android:textSize="10sp"
            android:layout_marginBottom="4dp" />
        <TextView android:id="@+id/tvNearbyStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Nearby: idle" android:textColor="@color/muted"
            android:textSize="11sp" android:fontFamily="monospace"
            android:layout_marginBottom="2dp" />
        <TextView android:id="@+id/tvFirebaseStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="@color/green"
            android:textSize="11sp" android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- APP MODE (hidden for CAM) -->
        <LinearLayout android:id="@+id/sectionMode"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border" android:layout_marginBottom="10dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="SPORT" android:textColor="@color/muted"
                android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <Button android:id="@+id/btnModeRollerblade"
                    android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                    android:text="ROLLERBLADE" android:textSize="11sp"
                    android:textColor="@color/bg" android:background="@color/accent"
                    android:layout_marginEnd="6dp" />
                <Button android:id="@+id/btnModeBoxing"
                    android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                    android:text="BOXING" android:textSize="11sp"
                    android:textColor="@color/accent" android:background="@color/surface" />
            </LinearLayout>
        </LinearLayout>

        <!-- DEVICE SIDE (hidden for CAM) -->
        <LinearLayout android:id="@+id/sectionSide"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="SIDE" android:textColor="@color/muted"
                android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">
                <Button android:id="@+id/btnLeft"
                    android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
                    android:text="LEFT" android:textSize="16sp"
                    android:textColor="@color/bg" android:background="@color/accent"
                    android:layout_marginEnd="6dp" />
                <Button android:id="@+id/btnRight"
                    android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
                    android:text="RIGHT" android:textSize="16sp"
                    android:textColor="@color/accent" android:background="@color/surface" />
            </LinearLayout>
            <TextView android:id="@+id/tvModeHint"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Left pocket" android:textColor="@color/muted"
                android:textSize="11sp" android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- LIVE VIEW -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border" android:layout_marginBottom="10dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="LIVE VIEW (WiFi)" android:textColor="@color/muted"
            android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="6dp" />
        <TextView android:id="@+id/tvLiveUrl"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="starting…" android:textColor="@color/accent2" android:textSize="16sp"
            android:fontFamily="monospace" android:layout_marginBottom="2dp"
            android:clickable="true" android:focusable="true" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Tap to show QR code · same WiFi only"
            android:textColor="@color/muted" android:textSize="10sp"
            android:layout_marginBottom="10dp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="CLOUD RELAY (fallback)" android:textColor="@color/muted"
            android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="6dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <EditText android:id="@+id/etRelayUrl"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:hint="yourapp.railway.app"
                android:inputType="text|textNoSuggestions"
                android:textSize="13sp" android:fontFamily="monospace"
                android:textColor="@color/accent2" android:textColorHint="@color/muted"
                android:background="@color/surface"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:imeOptions="actionGo" android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnConnect"
                android:layout_width="wrap_content" android:layout_height="44dp"
                android:text="CONNECT" android:textSize="11sp"
                android:textColor="@color/bg" android:background="@color/accent"
                android:paddingStart="12dp" android:paddingEnd="12dp" />
        </LinearLayout>
        <TextView android:id="@+id/tvRelayStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Relay: idle" android:textColor="@color/muted"
            android:textSize="11sp" android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <!-- RECORDING -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border" android:layout_marginBottom="10dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="RECORDING" android:textColor="@color/muted"
            android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp" />

        <TextView android:id="@+id/tvRoundInfo"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="@color/accent" android:textSize="11sp"
            android:fontFamily="monospace" android:gravity="center"
            android:visibility="gone" android:layout_marginBottom="4dp" />
        <TextView android:id="@+id/tvTimer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="00:00" android:textColor="@color/accent2" android:textSize="52sp"
            android:fontFamily="sans-serif-condensed" android:gravity="center"
            android:letterSpacing="0.1" android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btnRecord"
            android:layout_width="match_parent" android:layout_height="64dp"
            android:text="●  START RECORDING" android:textSize="20sp" android:letterSpacing="0.08"
            android:textColor="@color/bg" android:background="@color/accent"
            android:layout_marginBottom="16dp" />

        <!-- LIVE SENSORS (hidden for CAM) -->
        <LinearLayout android:id="@+id/sectionSensors"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/border" android:layout_marginBottom="10dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="LIVE SENSORS" android:textColor="@color/muted"
                android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface" android:padding="8dp" android:layout_marginEnd="4dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="AX" android:textColor="@color/muted" android:textSize="9sp" />
                    <TextView android:id="@+id/tvAx" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="0.00"
                        android:textColor="@color/accent2" android:textSize="15sp" android:fontFamily="monospace" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface" android:padding="8dp" android:layout_marginEnd="4dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="AY" android:textColor="@color/muted" android:textSize="9sp" />
                    <TextView android:id="@+id/tvAy" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="9.81"
                        android:textColor="@color/accent2" android:textSize="15sp" android:fontFamily="monospace" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface" android:padding="8dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="AZ" android:textColor="@color/muted" android:textSize="9sp" />
                    <TextView android:id="@+id/tvAz" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="0.00"
                        android:textColor="@color/accent2" android:textSize="15sp" android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface" android:padding="8dp" android:layout_marginEnd="4dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="GX" android:textColor="@color/muted" android:textSize="9sp" />
                    <TextView android:id="@+id/tvGx" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="0.000"
                        android:textColor="@color/green" android:textSize="15sp" android:fontFamily="monospace" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface" android:padding="8dp" android:layout_marginEnd="4dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="GY" android:textColor="@color/muted" android:textSize="9sp" />
                    <TextView android:id="@+id/tvGy" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="0.000"
                        android:textColor="@color/green" android:textSize="15sp" android:fontFamily="monospace" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="@color/surface" android:padding="8dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="GZ" android:textColor="@color/muted" android:textSize="9sp" />
                    <TextView android:id="@+id/tvGz" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="0.000"
                        android:textColor="@color/green" android:textSize="15sp" android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <TextView android:id="@+id/tvGyroStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="GYRO: checking…"
                android:textColor="@color/muted" android:textSize="11sp" android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />
            <TextView android:id="@+id/tvGpsStatus"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="GPS: idle"
                android:textColor="@color/muted" android:textSize="11sp" android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">
                <TextView android:id="@+id/tvPeakAccel"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Peak: 0.0g" android:textColor="@color/muted"
                    android:textSize="12sp" android:fontFamily="monospace" />
                <TextView android:id="@+id/tvSampleCount"
                    android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Samples: 0" android:textColor="@color/muted"
                    android:textSize="12sp" android:fontFamily="monospace" android:gravity="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- NAVIGATION -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border" android:layout_marginBottom="10dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <Button android:id="@+id/btnSessions"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="SESSIONS" android:textSize="11sp"
                android:textColor="@color/accent" android:background="@color/surface"
                android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btnSocial"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="SOCIAL" android:textSize="11sp"
                android:textColor="@color/accent" android:background="@color/surface"
                android:layout_marginEnd="4dp" />
            <Button android:id="@+id/btnChallenge"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="CHALLENGE" android:textSize="11sp"
                android:textColor="@color/accent" android:background="@color/surface" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
