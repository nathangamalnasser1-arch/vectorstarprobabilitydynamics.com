<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg"
    android:padding="16dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="SOCIAL FEED" android:textColor="@color/accent" android:textSize="24sp"
        android:fontFamily="sans-serif-condensed" android:letterSpacing="0.1"
        android:layout_marginBottom="4dp" />
    <TextView android:id="@+id/tvMyUid"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="" android:textColor="@color/muted" android:textSize="10sp"
        android:fontFamily="monospace" android:layout_marginBottom="16dp" />

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="FOLLOW USER" android:textColor="@color/muted"
        android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="6dp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="20dp">
        <EditText android:id="@+id/etFollowUid"
            android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
            android:hint="Paste their UID" android:textSize="13sp"
            android:textColor="@color/accent2" android:textColorHint="@color/muted"
            android:background="@color/surface" android:paddingStart="10dp" android:paddingEnd="10dp"
            android:layout_marginEnd="8dp" />
        <Button android:id="@+id/btnFollow"
            android:layout_width="wrap_content" android:layout_height="44dp"
            android:text="FOLLOW" android:textSize="11sp" android:letterSpacing="0.04"
            android:textColor="@color/bg" android:background="@color/accent" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/border" android:layout_marginBottom="10dp" />
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="RECENT SESSIONS" android:textColor="@color/muted"
        android:textSize="10sp" android:letterSpacing="0.15" android:layout_marginBottom="8dp" />

    <ListView android:id="@+id/listFeed"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:dividerHeight="1dp" android:divider="@color/border" />
</LinearLayout>
